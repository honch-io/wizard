{
  "compilerOptions": {
    "declaration": true,
    "stripInternal": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "noFallthroughCasesInSwitch": true,
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "target": "ES2022",
    "skipLibCheck": true,
    "types": [],
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "sourceMap": true,
    "inlineSources": true,
    "esModuleInterop": true,
    "jsx": "react-jsx",
    "paths": {
      "@env": ["./src/env.ts"],
      "@lib/*": ["./src/lib/*"],
      "@utils/*": ["./src/utils/*"],
      "@ui": ["./src/ui/index.ts"],
      "@ui/*": ["./src/ui/*"],
      "@steps": ["./src/steps/index.ts"],
      "@steps/*": ["./src/steps/*"],
      "@frameworks/*": ["./src/frameworks/*"]
    }
  }
}
