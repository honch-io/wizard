{
  "name": "@honch/honcho-wizard",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Agent-powered Honch SDK setup wizard",
  "bin": {
    "honcho": "dist/bin.mjs"
  },
  "files": [
    "dist",
    "README.md",
    "SPEC",
    "AGENTS.md"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsx src/bin.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "format": "biome check --write .",
    "format:check": "biome check ."
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.146",
    "ink": "^6.8.0",
    "react": "^19.2.4",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.14",
    "tsdown": "^0.21.9",
    "tsx": "^4.20.3",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "bun@1.3.3"
}
