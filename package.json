{
  "name": "@honch/start",
  "version": "2.3.0",
  "type": "module",
  "description": "Agent-powered Honch SDK setup wizard",
  "license": "MIT",
  "author": "Honch",
  "homepage": "https://github.com/honch-io/wizard#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/honch-io/wizard.git"
  },
  "bugs": {
    "url": "https://github.com/honch-io/wizard/issues"
  },
  "keywords": [
    "honch",
    "sdk",
    "wizard",
    "installer",
    "esp-idf",
    "firmware",
    "cli"
  ],
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "honch": "dist/bin.mjs"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "tsdown && node -e \"require('node:fs').cpSync('src/skills','dist/skills',{recursive:true})\"",
    "dev": "tsx src/bin.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "format": "biome check --write .",
    "format:check": "biome check .",
    "prepublishOnly": "bun run typecheck && bun run test && bun run build"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.146",
    "@honch/agent-core": "workspace:*",
    "ink": "^6.8.0",
    "react": "^19.2.4",
    "tar": "^7.5.16",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.14",
    "tsdown": "^0.21.9",
    "tsx": "^4.20.3",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "bun@1.3.3"
}
